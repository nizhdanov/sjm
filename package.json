{
  "name": "sjm",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "lint-staged": "lint-staged"
  },
  "devDependencies": {
    "@sjm/eslint": "*",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "simple-git-hooks": "^2.11.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run lint-staged"
  },
  "lint-staged": {
    "*": "turbo lint"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.9.1",
  "workspaces": [
    "apps/*",
    "tools/*"
  ]
}
