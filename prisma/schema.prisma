generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Institute {
  title     String    @unique
  faculties Faculty[]
}

model Faculty {
  title          String              @unique
  instituteTitle String
  institute      Institute           @relation(fields: [instituteTitle], references: [title])
  specialties    Specialty[]
  teachers       TeachersOfFaculty[]
}

model Specialty {
  facultyTitle String
  code         String   @unique
  title        String   
  step         String
  points       Int
  courses      Course[]
  faculty      Faculty  @relation(fields: [facultyTitle], references: [title])
  values       Value[]
}

model Course {
  id            String            @id @default(cuid())
  descrition    String
  year          Int
  specialtyCode String
  speciality    Specialty         @relation(fields: [specialtyCode], references: [code], onDelete: Cascade)
  subjects      SubjectsCourses[]
}

model Subject {
  name        String             @unique
  specialties SubjectsCourses[]
  teachers    TeachersSubjects[]
}

model SubjectsCourses {
  courseId    String
  subjectName String
  course      Course  @relation(fields: [courseId], references: [id])
  subject     Subject @relation(fields: [subjectName], references: [name])

  @@id([courseId, subjectName])
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  teacherId String?  @unique
  teacher   Teacher? @relation(fields: [teacherId], references: [id])
}

model TeachersOfFaculty {
  teacherId    String
  facultyTitle String
  faculty      Faculty @relation(fields: [facultyTitle], references: [title])
  teacher      Teacher @relation(fields: [teacherId], references: [id])

  @@id([teacherId, facultyTitle])
}

model Teacher {
  id          String              @id @default(cuid())
  lastName    String
  firstName   String
  midlleName  String
  specialties TeachersOfFaculty[]
  skills      TeachersSkills[]
  subjects    TeachersSubjects[]
  user        User?
}

model TeachersSkills {
  teacherId String
  skillName String
  skill     Skill   @relation(fields: [skillName], references: [name])
  teacher   Teacher @relation(fields: [teacherId], references: [id])

  @@id([teacherId, skillName])
}

model TeachersSubjects {
  teacherId   String
  subjectName String
  position    String
  subject     Subject @relation(fields: [subjectName], references: [name])
  teacher     Teacher @relation(fields: [teacherId], references: [id])

  @@id([teacherId, subjectName])
}

model Skill {
  name     String           @unique
  teachers TeachersSkills[]
}

model Value {
  id            String            @id @default(cuid())
  specialtyCode String
  weight        Float
  speciality    Specialty         @relation(fields: [specialtyCode], references: [code], onDelete: Cascade)
  options       ValuesInOptions[]
}

model Question {
  order   Int      @unique
  body    String   @unique
  options Option[]
}

model Option {
  id            String            @id @default(cuid())
  label         String
  questionOrder Int
  question      Question          @relation(fields: [questionOrder], references: [order])
  values        ValuesInOptions[]
}

model ValuesInOptions {
  valueId  String
  optionId String
  option   Option @relation(fields: [optionId], references: [id])
  value    Value  @relation(fields: [valueId], references: [id])

  @@id([valueId, optionId])
}
