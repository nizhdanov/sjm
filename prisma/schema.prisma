generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Specialty {
  id     String  @id @default(cuid())
  code   String  @unique
  title  String
  values Value[]
}

model Value {
  id          String            @id @default(cuid())
  weight      Float
  specialtyId String
  speciality  Specialty         @relation(fields: [specialtyId], references: [id], onDelete: Cascade)
  options     ValuesInOptions[]
}

model Question {
  id      String   @id @default(cuid())
  order   Int      @unique
  body    String
  options Option[]
}

model Option {
  id         String            @id @default(cuid())
  label      String
  questionId String
  question   Question          @relation(fields: [questionId], references: [id])
  values     ValuesInOptions[]
}

model ValuesInOptions {
  valueId  String
  optionId String
  option   Option @relation(fields: [optionId], references: [id])
  value    Value  @relation(fields: [valueId], references: [id])

  @@id([valueId, optionId])
}
