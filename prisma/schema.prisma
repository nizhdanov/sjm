generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Specialty {
  id     String  @id @default(cuid())
  code   String  @unique
  title  String
  values Value[]
}

model Value {
  id            String            @id @default(cuid())
  specialtyCode String
  weight        Float
  speciality    Specialty         @relation(fields: [specialtyCode], references: [code], onDelete: Cascade)
  options       ValuesInOptions[]
}

model Question {
  id      String   @id @default(cuid())
  order   Int      @unique
  body    String   @unique
  options Option[]
}

model Option {
  id            String            @id @default(cuid())
  label         String
  questionOrder Int
  question      Question          @relation(fields: [questionOrder], references: [order])
  values        ValuesInOptions[]
}

model ValuesInOptions {
  valueId  String
  optionId String
  option   Option @relation(fields: [optionId], references: [id])
  value    Value  @relation(fields: [valueId], references: [id])

  @@id([valueId, optionId])
}
